# =============================================================================
# Odoo MCP Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For Claude.ai integration with Google OAuth

# =============================================================================
# Odoo Connection
# =============================================================================
ODOO_URL=https://your-odoo-instance.example.com
ODOO_DB=your-database-name
ODOO_API_KEY=your_odoo_api_key_here

# Service-account login used with ODOO_API_KEY. For the per-user identity bridge this is
# the dedicated admin account (e.g. svc-mcp@example.com) — always supplied
# here via config, never hardcoded in the app.
ODOO_USERNAME=svc-erp-mcp@your-domain.example.com

# Alternative: password instead of API key (not recommended for production)
# ODOO_PASSWORD=your_password

# =============================================================================
# Google OAuth 2.1 Configuration
# =============================================================================
# Provider type (google or custom)
OAUTH_PROVIDER=google

# Google OAuth Client Credentials
# Get from: https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your_client_secret_here

# Google OAuth Endpoints (defaults - usually don't need to change)
OAUTH_AUTHORIZATION_SERVER=https://accounts.google.com
OAUTH_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
OAUTH_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
OAUTH_ISSUER=https://accounts.google.com

# Resource identifier (your MCP server URL)
OAUTH_RESOURCE_IDENTIFIER=https://your-mcp-server.run.app

# OAuth Redirect URI (for Claude.ai callback)
# This must match one of the authorized redirect URIs in Google Console
OAUTH_REDIRECT_URI=https://your-mcp-server.run.app/oauth/callback

# OAuth scopes to request
OAUTH_SCOPES=openid email profile

# Internal email domain for granting extended write scopes
# Users with emails @yourdomain.com get additional write permissions
INTERNAL_EMAIL_DOMAIN=yourdomain.com

# =============================================================================
# Optional Features (defaults work against a stock Odoo)
# =============================================================================
# Extra hr.employee fields to surface on the self profile, as a JSON object
# mapping output key -> Odoo field name. Leave unset for a stock Odoo.
# Example (custom fields added by an HR addon / external HR system sync):
# EMPLOYEE_CUSTOM_FIELDS={"preferred_name": "x_preferred_name", "division": "x_division"}

# Document (DMS) folder names, comma-separated. Map to your Odoo Documents setup.
# DMS_ALLOWED_FOLDERS=Contracts,Identity
# DMS_RESTRICTED_FOLDERS=Background Checks,Offboarding Documents

# Tool groups to expose, comma-separated: "crud", "employee" (default "crud,employee").
# Use "crud" for a generic admin bridge, or "employee" for self-service only.
# ENABLED_TOOL_GROUPS=crud,employee

# OCA Sign tools. Requires the community `sign_oca` addon (sign.oca.* models).
# Disabled by default; set to true to expose the signature tools.
SIGN_MODULE_ENABLED=false

# =============================================================================
# HTTP Server Configuration
# =============================================================================
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# =============================================================================
# Development Settings
# =============================================================================
DEBUG=false

# Skip OAuth validation (DEVELOPMENT ONLY - never use in production!)
OAUTH_DEV_MODE=false

# No-auth modes for trusted/local single-instance use (never on a public network):
#   YOLO_MODE=read  -> read-only (only read tools are exposed)
#   YOLO_MODE=true  -> full read/write access
# See docs/DEPLOYMENT.md. Leave unset for OAuth.
# YOLO_MODE=

# =============================================================================
# Claude.ai MCP Integration
# =============================================================================
# To configure Claude.ai to use this MCP server:
#
# 1. Go to Claude.ai Settings > MCP Servers
# 2. Add new server with:
#    - URL: https://your-mcp-server.run.app/mcp
#    - Transport: streamable-http
#    - OAuth: Google (will use the configured client)
#
# Required redirect URIs in Google Console:
#   - https://claude.ai/oauth/callback
#   - https://claude.ai/api/auth/callback
#   - https://api.claude.ai/oauth/callback
#   - https://claude.ai/auth/callback
#   - https://claude.ai/api/mcp/auth_callback
#   - https://your-mcp-server.run.app/oauth/callback

# =============================================================================
# Test Configuration (for running pytest)
# =============================================================================
TEST_MCP_SERVER_URL=http://localhost:8080
TEST_AUTH_SERVER_URL=https://accounts.google.com
TEST_ODOO_URL=https://your-odoo-instance.example.com
TEST_ODOO_DB=your-database-name
TEST_ODOO_API_KEY=your_test_api_key
TEST_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
TEST_CLIENT_SECRET=your_client_secret
TEST_USER_EMAIL=test@example.com

# =============================================================================
# Per-User Identity Bridge (optional: src/odoo_mcp_bridge, `pip install .[bridge]`)
# =============================================================================
# A separate FastMCP app that performs Odoo actions AS the authenticated user
# (native record rules + correct create_uid), instead of as the service account.
#
# HARD DEPENDENCY: requires the companion Odoo addon `mcp_apikey_provisioning`
# (in odoo_addons/) installed on the Odoo server, and the service account
# (ODOO_USERNAME/ODOO_API_KEY above) to be an Odoo System Administrator.
# See docs/odoo-team-instructions.md. Without it, the bridge starts and logs a
# warning, but per-user Odoo calls fail with a clear message.
#
# Reuses ODOO_* and OAUTH_CLIENT_ID/OAUTH_CLIENT_SECRET/OAUTH_RESOURCE_IDENTIFIER above.
# Allowlist of who may connect (use '*' to allow any Google account):
BRIDGE_ALLOWED_DOMAINS=your-domain.example.com
# BRIDGE_ALLOWED_EMAILS=alice@example.com,bob@example.com
# Optional: map secondary Google sign-in emails to a canonical Odoo login, so one person
# can sign in with several addresses but act as one Odoo user. JSON or alias=canonical CSV:
# BRIDGE_EMAIL_ALIASES={"alice.personal@gmail.com":"alice@your-domain.example.com"}
# Secret for signing internal session state (generate a strong random value):
SESSION_SECRET=
# Per-user key vault backend: memory | encrypted_file | gcp_secret_manager
TOKEN_STORAGE_BACKEND=encrypted_file
# Required for encrypted_file (Fernet key):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
TOKEN_STORE_PATH=/var/lib/odoo-mcp/keys.json
# Minted key lifetime in days (server re-mints on expiry):
ODOO_KEY_TTL_DAYS=30
# Only for TOKEN_STORAGE_BACKEND=gcp_secret_manager:
# GCP_PROJECT=your-gcp-project
